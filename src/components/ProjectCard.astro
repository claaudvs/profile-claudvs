---
interface Props {
  title: string;
  description: string;
  tags: string[];
  github?: string | null;
  live?: string | null;
  featured?: boolean;
}

const { title, description, tags, github, live, featured = false } = Astro.props;
---

<article class:list={[
  'group relative bg-zinc-50 dark:bg-zinc-900 border rounded-xl p-6 flex flex-col gap-4 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-zinc-200/60 dark:hover:shadow-zinc-950/60',
  featured
    ? 'border-accent/40 hover:border-accent'
    : 'border-zinc-200 dark:border-zinc-800 hover:border-zinc-400 dark:hover:border-zinc-600',
]}>

  {featured && (
    <span class="absolute top-4 right-4 text-[10px] font-mono uppercase tracking-widest text-accent border border-accent/30 px-2 py-0.5 rounded-full">
      Featured
    </span>
  )}

  <!-- Title -->
  <h3 class="font-semibold text-lg pr-16">{title}</h3>

  <!-- Description -->
  <p class="text-zinc-500 dark:text-zinc-400 text-sm leading-relaxed flex-1">
    {description}
  </p>

  <!-- Tags -->
  <div class="flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="px-2 py-0.5 bg-zinc-200 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 text-xs rounded font-mono">
        {tag}
      </span>
    ))}
  </div>

  <!-- Links -->
  <div class="flex items-center gap-4 text-sm pt-1 border-t border-zinc-200 dark:border-zinc-800">
    {github && (
      <a
        href={github}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"/>
        </svg>
        GitHub
      </a>
    )}
    {live && (
      <a
        href={live}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 text-accent hover:text-indigo-500 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 3h6v6M10 14 21 3M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
        </svg>
        Live
      </a>
    )}
    {!github && !live && (
      <span class="text-zinc-400 dark:text-zinc-600 text-xs font-mono italic">private repo</span>
    )}
  </div>

</article>
