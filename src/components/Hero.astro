---
import Card from "./Card.astro";
import AvailableStatus from "./shared/AvailableStatus.astro";
import SocialLinks from "./shared/SocialLinks.astro";

const roles = [
  "Frontend Developer",
  "Open Source Contributor",
  "TypeScript Enthusiast",
];
const description =
  "Hi, I'm Claudio Vargas, a frontend engineer specialized in React and Next.js.";
---

<section id="home" class="relative max-h-screen flex pt-14 overflow-hidden">
  <div
    class="absolute inset-0 bg-[linear-gradient(to_right,#8882_1px,transparent_1px),linear-gradient(to_bottom,#8882_1px,transparent_1px)] bg-size-[48px_48px] dark:bg-[linear-gradient(to_right,#ffffff08_1px,transparent_1px),linear-gradient(to_bottom,#ffffff08_1px,transparent_1px)]"
  >
  </div>
  <Card className="w-full h-auto" title="Hello 🍕" description={description}>
    <div class="animate-fade-in-up" style="animation-delay: 100ms;">
      <SocialLinks isSocialNetwork={false} />
    </div>
    <div class="animate-fade-in-up" style="animation-delay: 200ms;">
      <AvailableStatus />
    </div>

    <div
      class="animate-fade-in-up bg-zinc-50 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl p-6 font-mono text-sm space-y-2"
      style="animation-delay: 300ms;"
    >
      <p class="text-zinc-400 dark:text-zinc-500 cursor-blink">
        // quick facts
      </p>
      <p>
        <span class="text-accent">const</span>
        <span class="text-zinc-700 dark:text-zinc-300">location =</span>
        <span class="text-emerald-600 dark:text-emerald-400">"Remote"</span>;
      </p>
      <p>
        <span class="text-accent">const</span>
        <span class="text-zinc-700 dark:text-zinc-300">experience =</span>
        <span class="text-emerald-600 dark:text-emerald-400">"5+ years"</span>;
      </p>
      <p>
        <span class="text-accent">const</span>
        <span class="text-zinc-700 dark:text-zinc-300">focus =</span>
        <span class="text-emerald-600 dark:text-emerald-400"
          >"Web Development"</span
        >;
      </p>
      <p>
        <span class="text-accent">const</span>
        <span class="text-zinc-700 dark:text-zinc-300">available =</span>
        <span class="text-blue-500 dark:text-blue-400">true</span>;
      </p>
    </div>
  </Card>
</section>

<script>
  const roles = [
    "Full-Stack Developer",
    "Open Source Contributor",
    "TypeScript Enthusiast",
  ];
  const el = document.getElementById("hero-role");
  let i = 0;

  setInterval(() => {
    if (!el) return;
    el.style.opacity = "0";
    el.style.transform = "translateY(-8px)";
    setTimeout(() => {
      i = (i + 1) % roles.length;
      el.textContent = roles[i];
      el.style.opacity = "1";
      el.style.transform = "translateY(0)";
    }, 300);
  }, 3000);
</script>

<style>
  #hero-role {
    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
  }
</style>
