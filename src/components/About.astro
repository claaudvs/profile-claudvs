---
import Card from "./Card.astro";

---

<section id="about" class="py-24 border-t border-zinc-200 dark:border-zinc-800">
  <!-- <Card date="16/03/2026" id="0002" /> -->
  <!-- <Card date="16/03/2026" id="0001" title="First Post" description="Hola primer post" /> -->
  <div class="max-w-5xl mx-auto px-6">
    <p class="font-mono text-accent text-sm mb-2" data-reveal>01. about</p>
    <h2 class="text-3xl font-bold mb-12" data-reveal>About Me</h2>
    <div class="grid md:grid-cols-2 gap-12 items-start" data-reveal="stagger">
      <div class="space-y-4 text-zinc-500 dark:text-zinc-400 leading-relaxed">
        <p>
          I'm a software developer with a passion for building elegant solutions
          to complex problems. I focus on writing clean, maintainable code and
          crafting intuitive user interfaces.
        </p>
        <p>
          When I'm not coding, I enjoy contributing to open-source projects,
          writing technical articles, and exploring new technologies.
        </p>
        <p>
          I believe great software is built on a foundation of curiosity,
          attention to detail, and a deep understanding of user needs.
        </p>
      </div>
      <div class="bg-zinc-50 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl p-6 font-mono text-sm space-y-2">
        <p class="text-zinc-400 dark:text-zinc-500">// quick facts</p>
        <p><span class="text-accent">const</span> <span class="text-zinc-700 dark:text-zinc-300">location</span> = <span class="text-emerald-600 dark:text-emerald-400">"Remote"</span>;</p>
        <p><span class="text-accent">const</span> <span class="text-zinc-700 dark:text-zinc-300">experience</span> = <span class="text-emerald-600 dark:text-emerald-400">"5+ years"</span>;</p>
        <p><span class="text-accent">const</span> <span class="text-zinc-700 dark:text-zinc-300">focus</span> = <span class="text-emerald-600 dark:text-emerald-400">"Web Development"</span>;</p>
        <p><span class="text-accent">const</span> <span class="text-zinc-700 dark:text-zinc-300">available</span> = <span class="text-blue-500 dark:text-blue-400">true</span>;</p>
      </div>
    </div>
  </div>
</section>
