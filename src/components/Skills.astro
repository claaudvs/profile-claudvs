---
const categories = [
  {
    title: "Languages",
    icon: "{ }",
    items: ["TypeScript", "JavaScript", "SQL"],
  },
  {
    title: "Frontend",
    icon: "</>",
    items: ["React", "Astro", "Next.js", "Angular", "TailwindCSS"],
  },
  {
    title: "Backend",
    icon: "[ ]",
    items: ["Nest", ".Net"],
  },
  {
    title: "Tools",
    icon: "~/",
    items: ["Git", "Docker", "CI/CD"],
  },
];
---

<section
  id="skills"
  class="py-24 border-t border-zinc-200 dark:border-zinc-800"
>
  <div class="max-w-5xl mx-auto px-6">
    <p class="font-mono text-accent text-sm mb-2" data-reveal>01. skills</p>
    <h2 class="text-3xl font-bold mb-12" data-reveal>Skills</h2>

    <div
      class="grid grid-cols-1 sm:grid-cols-2 gap-6"
      data-reveal="stagger"
    >
      {
        categories.map((category) => (
          <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900/60 p-5 hover:border-accent/40 transition-colors duration-300">
            <div class="flex items-center gap-3 mb-4">
              <span class="font-mono text-accent text-xs font-medium bg-accent/10 px-2 py-1 rounded-md">
                {category.icon}
              </span>
              <p class="font-mono text-zinc-500 dark:text-zinc-400 text-xs">
                // {category.title.toLowerCase()}
              </p>
            </div>
            <div class="flex flex-wrap gap-2">
              {category.items.map((skill) => (
                <span class="px-3 py-1 rounded-full text-sm font-mono border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300 hover:border-accent hover:text-accent transition-colors duration-200 cursor-default">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
