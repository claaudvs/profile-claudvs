---
const socials = [
  { label: 'GitHub', href: 'https://github.com/yourusername' },
  { label: 'LinkedIn', href: 'https://linkedin.com/in/yourusername' },
  { label: 'Twitter', href: 'https://twitter.com/yourusername' },
];
---

<section id="contact" class="py-24 border-t border-zinc-200 dark:border-zinc-800">
  <div class="max-w-5xl mx-auto px-6">
    <p class="font-mono text-accent text-sm mb-2" data-reveal>05. contact</p>
    <h2 class="text-3xl font-bold mb-4" data-reveal>Get in Touch</h2>
    <p class="text-zinc-500 dark:text-zinc-400 max-w-lg mb-10 leading-relaxed" data-reveal>
      I'm open to new opportunities and interesting projects. Feel free to reach
      out — I'll get back to you as soon as possible.
    </p>
    <div class="flex flex-col sm:flex-row gap-6 items-start">
      <a
        href="mailto:hello@yourname.dev"
        class="px-5 py-2.5 bg-accent text-white text-sm font-medium rounded-lg hover:bg-indigo-500 transition-colors"
      >
        hello@yourname.dev
      </a>
      <div class="flex items-center gap-6">
        {socials.map(({ label, href }) => (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
          >
            {label}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
