---
import Card from "../components/Card.astro";
import Nav from "../components/Nav.astro";
import Layout from "../layouts/Layout.astro";
import reactimg from "../assets/img/react.png";
import { Image } from "astro:assets";
const categoriesItems = [
    {
        title: "Frontend",
        items: ["React", "Astro", "Next.js", "TailwindCSS"],
    },
    {
        title: "Languages",
        items: ["TypeScript", "JavaScript", "Python", "SQL"],
    },
    {
        title: "Backend",
        items: ["Node.js", "Express", "PostgreSQL", "Redis"],
    },
    {
        title: "Tools",
        items: ["Git", "Docker", "Linux", "CI/CD"],
    },
];
const frontend = [
    {
        title: "React",
        description:
            "Experience building complex SPAs with React, utilizing hooks, context, and performance optimizations.",
        img: "/icons/react.svg",
    },
    {
        title: "Astro",
        description:
            "Experience building static sites and server-rendered applications with Astro.",
        img: "/icons/astro.svg",
    },
    {
        title: "Next.js",
        description:
            "Experience building server-side rendered applications with Next.js.",
        img: "/icons/next.svg",
    },
    {
        title: "TailwindCSS",
        description:
            "Experience building responsive and modern UIs with TailwindCSS.",
        img: "/icons/tailwindcss.svg",
    },
    {
        title: "Vue.js",
        description:
            "Experience building SPAs with Vue.js, utilizing the Composition API and Vue Router.",
        img: "/icons/vue.svg",
    },
    {
        title: "Svelte",
        description:
            "Experience building reactive applications with Svelte, leveraging its unique reactivity model.",
        img: "/icons/svelte.svg",
    },
];
---

<Layout title="Dev Portfolio" description="Personal developer portfolio">
    <Nav />
    <main>
        <section
            id="home"
            class="relative max-h-screen flex pt-14 overflow-hidden py-4"
        >
            <Card
                className="w-full h-auto"
                title="Skills Frontend 🧑‍🚀"
                description="Frontend Skills I enjoy building modern web interfaces that are fast, clean, and scalable. Most of my work focuses on React, Next.js, and TypeScript, where I design component-based architectures and maintainable frontend systems. I have worked on complex applications such as financial dashboards and enterprise platforms, where reliability, performance, and clear UI flows are essential. I like writing well-structured code, creating reusable UI components, and continuously improving performance and user experience. "
            />
        </section>
        <section>
            <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
                {
                    frontend.map((item, index) => (
                        <Card
                            className="break-inside-avoid"
                            id={`frontend-${index + 1}`}
                            label={item.title}
                            description={item.description}
                            image={item.img}
                        />
                    ))
                }
            </div>
        </section>

        <!-- <About /> -->
        <!-- 
    <Projects />
    <BlogPreview posts={posts} />
    <Contact /> -->
    </main>
    <!-- <Footer /> -->
</Layout>
